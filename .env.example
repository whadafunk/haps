# ============================================================
# Haps — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored and should never be committed.
# ============================================================

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
APP_URL=https://events.yourdomain.com
APP_DOMAIN=events.yourdomain.com
INSTANCE_NAME=My Events

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DB_USER=eventapp
DB_PASSWORD=changeme_use_a_strong_password
DB_NAME=eventapp

# ------------------------------------------------------------
# Secrets
# Generate with: openssl rand -base64 32
# Both must be at least 32 characters. App will refuse to start if not.
# ------------------------------------------------------------
SESSION_SECRET=
JWT_SECRET=

# ------------------------------------------------------------
# Admin — first-run setup only
# These are only used when no admin account exists yet.
# After the first admin is created via /setup, these are ignored.
# ------------------------------------------------------------
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_INITIAL_PASSWORD=changeme_immediately

# ------------------------------------------------------------
# Email via SMTP (optional)
# Leave SMTP_HOST blank to disable email entirely.
# The app still works without email; edit links are shown on screen only.
# ------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false        # set to true for port 465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ------------------------------------------------------------
# SMS via Twilio (optional, Phase 2+)
# Leave TWILIO_ACCOUNT_SID blank to disable SMS.
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ------------------------------------------------------------
# File Storage
# STORAGE_TYPE=local  → files stored in the Docker volume at STORAGE_PATH
# STORAGE_TYPE=s3     → files stored in S3-compatible bucket (MinIO, R2, etc.)
# ------------------------------------------------------------
STORAGE_TYPE=local
STORAGE_PATH=/uploads
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
# Allow anyone to create events (true) or only logged-in organizers (false)
OPEN_EVENTS=false

# Allow anyone to register a member account (true) or invite-only (false)
OPEN_REGISTRATION=true

# Auto-delete events N days after their end date. Leave blank to disable.
AUTO_EXPIRE_DAYS=

# ------------------------------------------------------------
# Development only
# ------------------------------------------------------------
# Set to true to disable rate limiting locally
DISABLE_RATE_LIMIT=false

# Set to true to enable Drizzle Studio (DB explorer) at /db-studio
ENABLE_DB_STUDIO=false
