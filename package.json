    "prettier-plugin-svelte": "^3.2.0",
    "svelte-eslint-parser": "^0.43.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
